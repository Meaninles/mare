{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Mare",
  "version": "0.1.0",
  "identifier": "com.mare.client",
  "build": {
    "beforeDevCommand": "cmd /c .\\node_modules\\.bin\\cnpm.cmd run dev",
    "beforeBuildCommand": "cmd /c .\\node_modules\\.bin\\cnpm.cmd run build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "windows": [
      {
        "title": "Mare",
        "width": 1440,
        "height": 900,
        "minWidth": 1200,
        "minHeight": 760,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
