{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Mare",
  "version": "0.1.0",
  "identifier": "com.mare.client",
  "build": {
    "beforeDevCommand": "cmd /c .\\node_modules\\.bin\\cnpm.cmd run dev",
    "beforeBuildCommand": "cmd /c .\\node_modules\\.bin\\cnpm.cmd run build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "windows": [
      {
        "title": "Mare",
        "width": 1440,
        "height": 900,
        "minWidth": 1200,
        "minHeight": 760,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [],
    "resources": {
      "../backend/server.exe": "backend/server.exe",
      "../backend/tools/cloud115_bridge.py": "backend/tools/cloud115_bridge.py",
      "../backend/tools/search_ai.py": "backend/tools/search_ai.py",
      "../backend/tools/search_ai.requirements.txt": "backend/tools/search_ai.requirements.txt",
      "../.tools/pythonlibs": "pythonlibs",
      "../.tools/runtime/alist/extracted/alist.exe": "runtime/alist/alist.exe",
      "../.tools/runtime/aria2/extracted/aria2-1.37.0-win-64bit-build1/aria2c.exe": "runtime/aria2/aria2c.exe"
    }
  }
}
